# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Cloudflare Turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your-turnstile-site-key
TURNSTILE_SECRET_KEY=your-turnstile-secret-key

# URLs — no domains hardcoded; configure here
NEXT_PUBLIC_APP_URL=https://dash.7link.click
NEXT_PUBLIC_MARKETING_URL=https://7link.click
NEXT_PUBLIC_LINK_BASE_URL=https://dash.7link.click

# Auth stub: true = bypass login (demo mode; needs only the Supabase DB, no Google).
# Set to false (or remove) to switch back to real Google/email login.
NEXT_PUBLIC_AUTH_STUB=true
DEMO_USER_ID=00000000-0000-0000-0000-000000000001
