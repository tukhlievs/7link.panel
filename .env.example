# MOCK MODE (default ON): the whole panel runs in the browser with no backend —
# no Supabase, no auth, no Turnstile. Links are stored in localStorage so you can
# test the UI immediately. Set NEXT_PUBLIC_MOCK=false to switch to the real stack.
NEXT_PUBLIC_MOCK=true

# Public marketing site (used for footer legal links).
NEXT_PUBLIC_MARKETING_URL=https://7link.click

# ---- Everything below is only needed when NEXT_PUBLIC_MOCK=false ----

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Cloudflare Turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your-turnstile-site-key
TURNSTILE_SECRET_KEY=your-turnstile-secret-key

# URLs
NEXT_PUBLIC_APP_URL=https://dash.7link.click
NEXT_PUBLIC_LINK_BASE_URL=https://dash.7link.click

# Auth stub (real-stack only): bypass login but keep real Supabase data
NEXT_PUBLIC_AUTH_STUB=false
DEMO_USER_ID=00000000-0000-0000-0000-000000000001
